# Managed by Ansible — do not edit manually
*filter
:INPUT ACCEPT [0:0]
:FORWARD ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]

# Allow established/related connections
-A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT

# Allow loopback
-A INPUT -i lo -j ACCEPT

# Technitium Web UI — localhost + infra nodes only
-A INPUT -p tcp --dport 5380 -s 127.0.0.1 -j ACCEPT -m comment --comment "Technitium Web UI - localhost"
-A INPUT -p tcp --dport 5380 -s {{ dns_primary_ip }} -j ACCEPT -m comment --comment "Technitium Web UI - from infra1"
-A INPUT -p tcp --dport 5380 -s {{ dns_secondary_ip }} -j ACCEPT -m comment --comment "Technitium Web UI - from infra2"
-A INPUT -p tcp --dport 5380 -s {{ traefik_vip }} -j ACCEPT -m comment --comment "Technitium Web UI - from VIP"
-A INPUT -p tcp --dport 5380 -j DROP -m comment --comment "Block direct Technitium Web UI"

# Traefik API — localhost (keepalived health check) + vm-monitoring (Prometheus scrape)
-A INPUT -p tcp --dport 8080 -s 127.0.0.1 -j ACCEPT -m comment --comment "Traefik API - keepalived"
-A INPUT -p tcp --dport 8080 -s 172.16.86.21 -j ACCEPT -m comment --comment "Traefik API - vm-monitoring Prometheus"
-A INPUT -p tcp --dport 8080 -j DROP -m comment --comment "Block direct Traefik API"

# VRRP traffic between infra nodes
-A INPUT -p 112 -s {{ dns_primary_ip if inventory_hostname in groups['dns_secondary'] else dns_secondary_ip }} -j ACCEPT -m comment --comment "VRRP keepalived"

COMMIT
