services:
  traefik:
    container_name: traefik
    image: {{ traefik_image }}
    network_mode: host
    env_file:
      - .env
    volumes:
      - {{ docker_base_dir }}/traefik/config:/etc/traefik
      - {{ docker_base_dir }}/traefik/certs:/certs
    restart: unless-stopped
    labels:
      - "com.centurylinklabs.watchtower.enable=false"
    # Ports via network_mode: host
    # 80/tcp   → HTTP (redirect → HTTPS)
    # 443/tcp  → HTTPS
    # 8443/tcp → LXD Web UI (TCP passthrough, dedicated entrypoint)
