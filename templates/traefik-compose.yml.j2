services:
  traefik:
    container_name: traefik
    image: {{ traefik_image }}
    network_mode: host
    environment:
      - INFOMANIAK_ACCESS_TOKEN={{ infomaniak_api_token }}
    volumes:
      - {{ docker_base_dir }}/traefik/config:/etc/traefik
      - {{ docker_base_dir }}/traefik/certs:/certs
      - /var/run/docker.sock:/var/run/docker.sock:ro
    restart: unless-stopped
    labels:
      - "com.centurylinklabs.watchtower.enable=false"
    # Ports via network_mode: host
    # 80/tcp   → HTTP (redirect → HTTPS)
    # 443/tcp  → HTTPS
