http:
  routers:
{% for svc in traefik_services %}
    {{ svc.name }}:
      rule: "Host(`{{ svc.host }}`)"
      entryPoints: [websecure]
      service: {{ svc.name }}
      tls:
        certResolver: infomaniak
        domains:
          - main: "{{ domain }}"
            sans:
              - "*.{{ domain }}"
{% endfor %}
{% for svc in traefik_services | selectattr('redirect_root', 'defined') | list %}
    {{ svc.name }}-root-redirect:
      rule: "Host(`{{ svc.host }}`) && Path(`/`)"
      entryPoints: [websecure]
      middlewares:
        - {{ svc.name }}-redirect-root
      service: {{ svc.name }}
      tls:
        certResolver: infomaniak
        domains:
          - main: "{{ domain }}"
            sans:
              - "*.{{ domain }}"
{% endfor %}

{% if traefik_services | selectattr('redirect_root', 'defined') | list | length > 0 %}
  middlewares:
{% for svc in traefik_services | selectattr('redirect_root', 'defined') | list %}
    {{ svc.name }}-redirect-root:
      redirectRegex:
        regex: ".*"
        replacement: "https://{{ svc.host }}{{ svc.redirect_root }}"
        permanent: true
{% endfor %}
{% endif %}

  services:
{% for svc in traefik_services %}
    {{ svc.name }}:
      loadBalancer:
{% if svc.skip_tls_verify | default(false) %}
        serversTransport: insecure-skip-verify
{% endif %}
        servers:
          - url: "{{ svc.url }}"
{% endfor %}

{% if traefik_services | selectattr('skip_tls_verify', 'defined') | selectattr('skip_tls_verify') | list | length > 0 %}
  serversTransports:
    insecure-skip-verify:
      insecureSkipVerify: true
{% endif %}

# --- TLS passthrough for LXD Web UI ---
# Dedicated entrypoint :8443 has no TLS config → pure TCP passthrough.
# Using websecure (:443) breaks mTLS because Traefik terminates the wildcard cert first.
tcp:
  routers:
    lxd:
      rule: "HostSNI(`*`)"
      entryPoints: [lxd]
      service: lxd
      tls:
        passthrough: true

  services:
    lxd:
      loadBalancer:
        servers:
          - address: "{{ mc_node_01_ip }}:8443"
