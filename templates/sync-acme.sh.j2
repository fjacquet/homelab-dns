#!/bin/bash
# Sync acme.json from primary to secondary (cron every hour)
# Runs only on infra1 (primary)

set -euo pipefail

ACME_SRC="{{ docker_base_dir }}/traefik/certs/acme.json"
ACME_DEST="{{ ansible_user }}@{{ dns_secondary_ip }}:{{ docker_base_dir }}/traefik/certs/acme.json"

if [[ -f "$ACME_SRC" ]]; then
    rsync -az --chmod=F600 "$ACME_SRC" "$ACME_DEST" 2>/dev/null
fi
