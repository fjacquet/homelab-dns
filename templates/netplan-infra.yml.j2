network:
  version: 2
  ethernets:
    enp1s0:
      addresses:
        - {{ infra_ip }}/24
      routes:
        - to: default
          via: {{ gateway }}
      nameservers:
        addresses:
          - {{ dns_primary_ip }}
          - {{ dns_secondary_ip }}
          - 1.1.1.1
        search:
          - {{ domain }}
