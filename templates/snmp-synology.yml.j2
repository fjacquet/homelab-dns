# SNMP Exporter config for Synology NAS (DS923+)
# Community: {{ snmp_community }}
# Generated by Ansible — do not edit manually
# snmp_exporter 0.25+ format: auths top-level

auths:
  public_v2:
    community: {{ snmp_community }}
    version: 2

modules:
  synology:
    walk:
      - 1.3.6.1.4.1.6574.1
      - 1.3.6.1.4.1.6574.2.1
      - 1.3.6.1.4.1.6574.3.1
      - 1.3.6.1.4.1.6574.101.1
      - 1.3.6.1.2.1.2.2
      - 1.3.6.1.2.1.31.1.1

    metrics:
      # --- System ---
      - name: synology_cpu_user_percentage
        oid: 1.3.6.1.4.1.6574.1.1
        type: gauge
        help: CPU user percentage

      - name: synology_cpu_system_percentage
        oid: 1.3.6.1.4.1.6574.1.2
        type: gauge
        help: CPU system percentage

      - name: synology_cpu_iowait_percentage
        oid: 1.3.6.1.4.1.6574.1.3
        type: gauge
        help: CPU IO wait percentage

      - name: synology_system_status
        oid: 1.3.6.1.4.1.6574.1.4.1
        type: gauge
        help: System status (1=normal 2=failed)

      - name: synology_power_status
        oid: 1.3.6.1.4.1.6574.1.4.2
        type: gauge
        help: Power status (1=normal 2=failed)

      - name: synology_memory_total_real
        oid: 1.3.6.1.4.1.6574.1.7.1
        type: gauge
        help: Total real memory in KB

      - name: synology_memory_available_real
        oid: 1.3.6.1.4.1.6574.1.7.2
        type: gauge
        help: Available real memory in KB

      - name: synology_cpu_fan_status
        oid: 1.3.6.1.4.1.6574.1.8
        type: gauge
        help: CPU fan status (1=normal 2=failed)

      # --- Disks ---
      - name: synology_disk_status
        oid: 1.3.6.1.4.1.6574.2.1.1.5
        type: gauge
        help: Disk status (1=Normal 2=Initialized 3=NotInitialized 4=SystemPartitionFailed 5=Crashed)
        indexes:
          - labelname: diskID
            type: gauge

      - name: synology_disk_temperature
        oid: 1.3.6.1.4.1.6574.2.1.1.6
        type: gauge
        help: Disk temperature in Celsius
        indexes:
          - labelname: diskID
            type: gauge

      # --- RAID ---
      - name: synology_raid_status
        oid: 1.3.6.1.4.1.6574.3.1.1.3
        type: gauge
        help: RAID status (1=Normal 11=Degraded 12=Crashed)
        indexes:
          - labelname: raidID
            type: gauge

      - name: synology_raid_free_bytes
        oid: 1.3.6.1.4.1.6574.3.1.1.4
        type: gauge
        help: RAID free size in bytes
        indexes:
          - labelname: raidID
            type: gauge

      - name: synology_raid_total_bytes
        oid: 1.3.6.1.4.1.6574.3.1.1.5
        type: gauge
        help: RAID total size in bytes
        indexes:
          - labelname: raidID
            type: gauge

      # --- Volumes ---
      - name: synology_volume_status
        oid: 1.3.6.1.4.1.6574.101.1.1.5
        type: gauge
        help: Volume status (1=Normal 4=Crashed)
        indexes:
          - labelname: volumeID
            type: gauge

      - name: synology_volume_used_bytes
        oid: 1.3.6.1.4.1.6574.101.1.1.3
        type: gauge
        help: Volume used size in bytes
        indexes:
          - labelname: volumeID
            type: gauge

      - name: synology_volume_total_bytes
        oid: 1.3.6.1.4.1.6574.101.1.1.2
        type: gauge
        help: Volume total size in bytes
        indexes:
          - labelname: volumeID
            type: gauge

      # --- Network interfaces ---
      - name: synology_if_in_octets
        oid: 1.3.6.1.2.1.31.1.1.1.6
        type: counter
        help: Bytes received on interface
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: synology_if_out_octets
        oid: 1.3.6.1.2.1.31.1.1.1.10
        type: counter
        help: Bytes sent on interface
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: synology_if_oper_status
        oid: 1.3.6.1.2.1.2.2.1.8
        type: gauge
        help: Interface operational status (1=up 2=down)
        indexes:
          - labelname: ifIndex
            type: gauge
