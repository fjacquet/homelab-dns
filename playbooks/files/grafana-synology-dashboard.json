      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"1": {"color": "green", "index": 0, "text": "Normal"}}, "type": "value"},
            {"options": {"11": {"color": "orange", "index": 1, "text": "Degraded"}}, "type": "value"},
            {"options": {"12": {"color": "red", "index": 2, "text": "Crashed"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "red", "value": 11}]}
