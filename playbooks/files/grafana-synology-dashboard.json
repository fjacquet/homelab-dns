        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "synology_volume_used_bytes", "legendFormat": "Used Vol {{volumeID}}"},
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "synology_volume_total_bytes", "legendFormat": "Total Vol {{volumeID}}"}
