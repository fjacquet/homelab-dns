      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "100 * synology_volume_used_bytes / synology_volume_total_bytes", "legendFormat": "Vol {{volumeID}}", "instant": true}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
